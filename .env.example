# ── Vertex AI (uses gcloud Application Default Credentials) ────
# Run once to authenticate:
#   gcloud auth login
#   gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION=us-central1

# ── Deezer ───────────────────────────────────────────────────────
# No API key needed — Deezer public endpoints are fully open.

# ── Local dev speed ───────────────────────────────────────────────
# Set to 1 to reduce EDA/critic iterations for faster local testing.
# Local→Vertex AI round-trips are slow; Cloud Run (same region) is fast.
# Do NOT set this in production / Cloud Run deployment.
# FAST_MODE=1
